{
  "mcpServers": {
    "namba-search": {
      "title": "Namba Search",
      "description": "Retrieve and research public web content through safe public-web fetch tools.",
      "icons": [
        {
          "src": "./assets/icon.png",
          "mimeType": "image/png",
          "sizes": [
            "512x512"
          ]
        }
      ],
      "command": "python3",
      "args": [
        "./scripts/launch_mcp.py"
      ],
      "cwd": ".",
      "startup_timeout_sec": 120,
      "tool_timeout_sec": 180
    }
  }
}
